# Copy this file to .env and fill in your values.
# .env is gitignored — your API key will never be committed.

# Required: Anthropic API key
# Webflow team: get this from 1Password (search "Zoom Notes Assistant")
# External users: create your own at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Optional: where to save generated note files
# Default: ~/Desktop/Meeting Notes/Notes
# Obsidian users: point this at YourVault/Meetings/Notes
ZOOM_NOTES_OUTPUT_DIR=

# Optional: where to save raw transcript files
# Default: ~/Desktop/Meeting Notes/Transcripts
# Obsidian users: point this at YourVault/Meetings/Transcripts
ZOOM_NOTES_TRANSCRIPTS_DIR=

# Optional: proxy API endpoint
# When set, API calls route through this URL instead of api.anthropic.com directly.
# The proxy receives the transcript and returns the summary — the Claude key
# never needs to be on your machine. Leave blank to use the direct Anthropic API.
ZOOM_NOTES_API_URL=
