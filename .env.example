# Zoom Meeting Notes Assistant — environment variable overrides
#
# API keys are stored in macOS Keychain by the menu bar app's Settings UI.
# The variables below are fallbacks ONLY — used when running zoom_notes.py
# from the CLI without the Swift app, and only if Keychain is empty.
#
# For normal use (the menu bar app), leave this file alone and configure
# everything in Settings.

# Optional: API keys for CLI usage. Prefer Keychain via the Settings window.
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GEMINI_API_KEY=

# Optional: where to save generated notes / transcripts (overrides settings.json).
# Obsidian users may point these at YourVault/Meetings/Notes etc.
# ZOOM_NOTES_OUTPUT_DIR=
# ZOOM_NOTES_TRANSCRIPTS_DIR=

# Optional: your Zoom display name (exactly as it appears in meetings).
# When set, the app gives a strong preference to the meeting where you appear
# as a speaker. Prevents double-booking confusion where a ghost meeting has
# more WAL entries than the one you actually attended.
# Example: ZOOM_NOTES_USER_NAME=Jane Smith
# ZOOM_NOTES_USER_NAME=
